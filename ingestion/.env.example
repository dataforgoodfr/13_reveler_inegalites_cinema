# --- Airbyte ---
AIRBYTE_HOST=localhost
AIRBYTE_PORT=8000
AIRBYTE_API_URL=http://localhost:8000/api/public/v1
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
AIRBYTE_DESTINATION_NAME=dst_pg_raw
AIRBYTE_DESTINATION_POSTGRES_PASSWORD=
AIRBYTE_CONNECTION_PREFIX=
AIRBYTE_SYNC_TIMEOUT_SECONDS=3600
AIRBYTE_SYNC_POLL_SECONDS=10

# --- Scraping browser ---
# Host port exposed by docker compose for local Browserless access
BROWSERLESS_PORT=3000

# --- Prefect ---
# Must stay identical for `prefect-server` and `prefect-worker`.
PREFECT_VERSION=3.4.24
# Host port exposed by docker compose for the local Prefect UI/API
PREFECT_PORT=4222
# Prefect uses the existing remote Postgres server, but with a dedicated database and user.
# If SSL is required by the server, append the asyncpg-compatible SSL query expected by your deployment.
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://prefect_user:<secret>@<db-host>:<db-port>/prefect
# Basic auth shared by Prefect UI/API server and workers.
PREFECT_SERVER_API_AUTH_STRING=<username>:<password>
PREFECT_API_AUTH_STRING=<username>:<password>

# --- Postgres ---
# Set these values to the environment you target (test or prod)
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=reveler_inegalites_cinema
DBT_USER_POSTGRES_PASSWORD=
POSTGRES_SSLMODE=disable

# --- dbt ---
DBT_THREADS=4
