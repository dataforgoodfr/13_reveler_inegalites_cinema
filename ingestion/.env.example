# --- Airbyte ---
AIRBYTE_HOST=localhost
AIRBYTE_PORT=8000
AIRBYTE_API_URL=http://localhost:8000/api/public/v1
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
AIRBYTE_DESTINATION_NAME=dst_pg_raw
AIRBYTE_DESTINATION_POSTGRES_PASSWORD=
AIRBYTE_CONNECTION_PREFIX=
AIRBYTE_SYNC_TIMEOUT_SECONDS=3600
AIRBYTE_SYNC_POLL_SECONDS=10

# --- Scraping browser ---
# Host port exposed by docker compose for local Browserless access
BROWSERLESS_PORT=3000

# --- Prefect ---
# Must stay identical for `prefect-server` and `prefect-worker`.
PREFECT_VERSION=3.4.24
# Host port exposed by docker compose for the local Prefect UI/API
PREFECT_PORT=4222
# Basic auth shared by Prefect UI/API server and workers.
PREFECT_AUTH_STRING=<username>:<password>
# Prefect uses the existing remote Postgres server, but with a dedicated database and user.
# If SSL is required by the server, append the asyncpg-compatible SSL query expected by your deployment.
PREFECT_API_DATABASE_CONNECTION_URL=postgresql+asyncpg://prefect_user:<secret>@<db-host>:<db-port>/prefect

# --- Postgres ---
# Set these values to the environment you target (test or prod)
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=reveler_inegalites_cinema
DBT_USER_POSTGRES_PASSWORD=
POSTGRES_SSLMODE=disable

# --- dbt ---
DBT_THREADS=4

# --- Ingestion request dispatcher ---
# The scheduled Prefect flow polls `ops.ingestion_run_requests` from the same project DB targeted by `POSTGRES_*`.
# By default it uses `prefect_user`. Set the password explicitly for the dispatcher runtime.
INGESTION_REQUEST_POSTGRES_USER=prefect_user
INGESTION_REQUEST_POSTGRES_PASSWORD=
INGESTION_REQUEST_MAIN_DEPLOYMENT_NAME=Lancer l'ingestion complete/lancer-ingestion-donnees
INGESTION_REQUEST_POLL_INTERVAL_SECONDS=300
INGESTION_REQUEST_CLAIM_TIMEOUT_SECONDS=3600
INGESTION_REQUEST_AUTO_INIT_QUEUE_SCHEMA=false
INGESTION_REQUEST_RUN_AIRBYTE_SYNC_STEP=false
INGESTION_REQUEST_RUN_DBT_PHASE_2_STEP=false
# Comma-separated list, required only when `INGESTION_REQUEST_RUN_AIRBYTE_SYNC_STEP=true`.
INGESTION_REQUEST_AIRBYTE_CONNECTION_NAMES=
INGESTION_REQUEST_ALLOCINE_CONFIG_PATH=/app/ingestion/scraping/allocine/config.json
